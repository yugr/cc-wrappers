set -eu

me=$(basename $0)

if test $(readlink -f $WRAPPER_CC) = $(readlink -f $0); then
  echo >&2 "$me: invalid target compiler: $WRAPPER_CC"
fi

$WRAPPER_CC ${WRAPPER_PRE_CFLAGS:-} "$@" ${WRAPPER_CFLAGS:-}
