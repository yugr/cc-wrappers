set -eu

me=$(basename $0)

if test $(readlink -f $WRAPPER_CC) = $(readlink -f $0); then
  echo >&2 "$me: invalid target compiler: $WRAPPER_CC"
fi

ARGS=()
BLACKLISTED=

for arg in "$@"; do
  if test -n "${WRAPPER_BLACKLIST:-}" && echo " $arg" | grep -q -- "${WRAPPER_BLACKLIST:-}"; then
    BLACKLISTED=1
  fi
  if test -n "${WRAPPER_STRIP:-}" && echo " $arg" | grep -q -- "${WRAPPER_STRIP:-}"; then
    continue
  fi
  ARGS+=("$arg")
done

if test -n "$BLACKLISTED"; then
  $WRAPPER_CC "${ARGS[@]}"
else
  $WRAPPER_CC ${WRAPPER_PRE_CFLAGS:-} "${ARGS[@]}" ${WRAPPER_CFLAGS:-}
fi
