set -eu

if test $(readlink -f $WRAPPER_CXX) = $(readlink -f $0); then
  echo >&2 "$me: invalid target compiler: $WRAPPER_CXX"
fi

ARGS=()
BLACKLISTED=

for arg in "$@"; do
  if test -n "${WRAPPER_BLACKLIST:-}" && echo " $arg" | grep -q -- "${WRAPPER_BLACKLIST:-}"; then
    BLACKLISTED=1
  fi
  if test -n "${WRAPPER_STRIP:-}" && echo " $arg" | grep -q -- "${WRAPPER_STRIP:-}"; then
    continue
  fi
  ARGS+=("$arg")
done

if test -n "$BLACKLISTED"; then
  $WRAPPER_CXX "${ARGS[@]}"
else
  $WRAPPER_CXX ${WRAPPER_PRE_CXXFLAGS:-} "${ARGS[@]}" ${WRAPPER_CXXFLAGS:-}
fi
